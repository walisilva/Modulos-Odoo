<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Heranca do formulario nativo de Pedido de Venda (sale.order).
        Adiciona:
          - Campos vehicle_id, leasing_start_date, leasing_end_date
          - Botao "Gerar CT-e OS" no header
          - Oculta abas e campos de comercio exterior / entrega fisica
    -->
    <record id="view_order_form_fleet_leasing" model="ir.ui.view">
        <field name="name">sale.order.form.fleet.leasing</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Botao "Gerar CT-e OS" no header, ao lado dos demais botoes -->
            <xpath expr="//header" position="inside">
                <button name="action_generate_cte_os_json"
                        type="object"
                        string="Gerar CT-e OS"
                        class="btn-primary"
                        states="sale,done"
                        help="Monta payload JSON do CT-e OS (hook para Gateway Fiscal)."/>
            </xpath>

            <!-- Campos de locacao abaixo do partner_id -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="vehicle_id"
                       options="{'no_create': True}"
                       placeholder="Selecione o onibus/veiculo..."
                       context="{'default_leasing_status': 'available'}"/>
                <div class="row">
                    <field name="leasing_start_date" class="col-6"
                           placeholder="Inicio da locacao"/>
                    <field name="leasing_end_date" class="col-6"
                           placeholder="Fim da locacao"/>
                </div>
            </xpath>

            <!-- Oculta a aba de "Outras Informacoes" (comercio exterior / incoterms)
                 pois tratamos exclusivamente de servico de locacao -->
            <xpath expr="//notebook/page[@name='order_line']" position="after">
                <page string="Locacao" name="fleet_leasing"
                      attrs="{'invisible': [('vehicle_id', '=', False)]}">
                    <group>
                        <group string="Veiculo">
                            <field name="vehicle_id"/>
                            <field name="leasing_start_date"/>
                            <field name="leasing_end_date"/>
                        </group>
                        <group string="Financeiro">
                            <field name="amount_untaxed" string="Valor Bruto"/>
                            <field name="amount_total" string="Valor Total"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <!-- Oculta campos de entrega / endereco de envio (nao se aplica a servico) -->
            <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='carrier_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='incoterm']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

        </field>
    </record>

</odoo>
