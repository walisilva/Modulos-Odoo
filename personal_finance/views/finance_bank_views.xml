<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_personal_finance_bank_list" model="ir.ui.view">
        <field name="name">personal.finance.bank.list</field>
        <field name="model">personal.finance.bank</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="action_personal_finance_banks" model="ir.actions.act_window">
        <field name="name">Bancos</field>
        <field name="res_model">personal.finance.bank</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
