<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_personal_finance_card_list" model="ir.ui.view">
        <field name="name">personal.finance.card.list</field>
        <field name="model">personal.finance.card</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name"/>
                <field name="bank_id"/>
                <field name="due_day"/>
            </list>
        </field>
    </record>

    <record id="action_personal_finance_cards" model="ir.actions.act_window">
        <field name="name">Cartões</field>
        <field name="res_model">personal.finance.card</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
