<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_personal_finance_balance_report_search" model="ir.ui.view">
        <field name="name">personal.finance.balance.report.search</field>
        <field name="model">personal.finance.balance.report</field>
        <field name="arch" type="xml">
            <search string="Buscar saldo">
                <filter string="Este ano" name="thisyear" domain="[('year', '=', time.strftime('%%Y'))]" help="Saldo do ano atual"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Ano" name="group_year" domain="[]" context="{'group_by': 'year'}"/>
                    <filter string="Mês" name="group_month" domain="[]" context="{'group_by': 'month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_personal_finance_balance_report_pivot" model="ir.ui.view">
        <field name="name">personal.finance.balance.report.pivot</field>
        <field name="model">personal.finance.balance.report</field>
        <field name="arch" type="xml">
            <pivot string="Evolução do saldo">
                <field name="year" type="row"/>
                <field name="month" type="row"/>
                <field name="account" type="col"/>
                <field name="balance" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_personal_finance_balance_report" model="ir.actions.act_window">
        <field name="name">Evolução do saldo</field>
        <field name="res_model">personal.finance.balance.report</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_personal_finance_balance_report_pivot"/>
        <field name="search_view_id" ref="view_personal_finance_balance_report_search"/>
        <field name="context">{'group_by': ['year', 'month']}</field>
    </record>
</odoo>
