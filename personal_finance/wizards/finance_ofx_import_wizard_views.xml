<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_personal_finance_ofx_import_wizard_form" model="ir.ui.view">
        <field name="name">personal.finance.ofx.import.wizard.form</field>
        <field name="model">personal.finance.ofx.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Extrato OFX">
                <field name="state" invisible="1"/>
                <group col="4" invisible="state != 'choose'">
                    <field name="account_id"/>
                    <field name="import_file" filename="import_filename"/>
                    <field name="import_filename" invisible="1"/>
                </group>
                <group col="1" invisible="not message">
                    <field name="message" readonly="1" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Importar" type="object" class="oe_highlight" invisible="state != 'choose'"/>
                    <button name="action_view_uncategorized" string="Ver sem categoria" type="object" class="oe_highlight" invisible="state != 'done'"/>
                    <button special="cancel" string="Fechar" class="oe_link"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_personal_finance_ofx_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar OFX</field>
        <field name="res_model">personal.finance.ofx.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
