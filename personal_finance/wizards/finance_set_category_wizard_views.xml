<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_personal_finance_set_category_wizard_form" model="ir.ui.view">
        <field name="name">personal.finance.set.category.wizard.form</field>
        <field name="model">personal.finance.set.category.wizard</field>
        <field name="arch" type="xml">
            <form string="Definir Categoria">
                <field name="category_id"/>
                <field name="rule_pattern"/>
                <footer>
                    <button name="action_set_category" string="Aplicar" type="object" class="oe_highlight"/>
                    <button special="cancel" string="Cancelar" class="oe_link"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
