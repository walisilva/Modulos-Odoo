<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_evolution_config_form" model="ir.ui.view">
        <field name="name">evolution.config.form</field>
        <field name="model">evolution.config</field>
        <field name="arch" type="xml">
            <form string="Configuração Evolution API">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Testar conexão" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="base_url" placeholder="http://192.168.0.100:8082"/>
                        <field name="api_key" password="True"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Instâncias (números)">
                            <field name="instance_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="phone_number"/>
                                    <field name="last_checked"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_evolution_config_list" model="ir.ui.view">
        <field name="name">evolution.config.list</field>
        <field name="model">evolution.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="base_url"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_evolution_config" model="ir.actions.act_window">
        <field name="name">Configuração Evolution API</field>
        <field name="res_model">evolution.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
