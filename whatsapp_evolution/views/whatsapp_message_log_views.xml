<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_whatsapp_message_log_list" model="ir.ui.view">
        <field name="name">whatsapp.message.log.list</field>
        <field name="model">whatsapp.message.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date" string="Data"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="instance_id"/>
                <field name="state" decoration-danger="state == 'error'"
                       decoration-success="state == 'sent'"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_message_log_form" model="ir.ui.view">
        <field name="name">whatsapp.message.log.form</field>
        <field name="model">whatsapp.message.log</field>
        <field name="arch" type="xml">
            <form string="Mensagem WhatsApp">
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="instance_id"/>
                        <field name="phone"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="message"/>
                        <field name="error_message" invisible="state != 'error'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_whatsapp_message_log" model="ir.actions.act_window">
        <field name="name">Mensagens Enviadas</field>
        <field name="res_model">whatsapp.message.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
